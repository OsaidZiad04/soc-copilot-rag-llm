APP_NAME="SOC Copilot"
APP_VERSION="1.0.0"

FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10485760
FILE_DEFAULT_CHUNK_SIZE=512000

POSTGRES_USERNAME="postgres"
POSTGRES_PASSWORD="<POSTGRES_PASSWORD>"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="soc_copilot"

GENERATION_BACKEND="OLLAMA"
EMBEDDING_BACKEND="COHERE"

OPENAI_API_KEY="<OPENAI_API_KEY_OR_EMPTY_FOR_LOCAL_OLLAMA>"
OPENAI_API_URL="http://localhost:11434/v1"
COHERE_API_KEY="<COHERE_API_KEY>"
OLLAMA_API_URL="http://localhost:11434/v1"

GENERATION_MODEL_ID="qwen3.5:9b"
EMBEDDING_MODEL_ID="embed-multilingual-light-v3.0"
EMBEDDING_MODEL_SIZE=384

INPUT_DAFAULT_MAX_CHARACTERS=4096
GENERATION_DAFAULT_MAX_TOKENS=2000
GENERATION_DAFAULT_TEMPERATURE=0.05

VECTOR_DB_BACKEND="PGVECTOR"
VECTOR_DB_PATH="qdrant_db"
VECTOR_DB_DISTANCE_METHOD="cosine"
VECTOR_DB_PGVEC_INDEX_THRESHOLD=100

RAG_TOP_K=5

VIRUSTOTAL_API_KEY="<OPTIONAL_VIRUSTOTAL_API_KEY>"
ABUSEIPDB_API_KEY="<OPTIONAL_ABUSEIPDB_API_KEY>"

PRIMARY_LANG="en"
DEFAULT_LANG="en"
